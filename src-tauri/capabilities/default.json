{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Kura デスクトップの権限。ローカルの Next.js サーバー(app URL)からコマンドを許可します。",
  "windows": ["main"],
  "remote": {
    "urls": ["http://localhost:3000", "http://localhost:*", "http://127.0.0.1:*"]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "dialog:default"
  ]
}
