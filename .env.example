# ───────────────────────────────────────────────────────────────────────────
# Kura environment variables
#
# Copy this file to `.env.local` and fill in the values.
# Kura is local-first: all data is stored on disk, so the app BUILDS and RUNS
# with NONE of these set. The only feature that uses the internet is the Gemini
# AI pipeline — and even that degrades gracefully (AI returns "未設定" stubs)
# until GEMINI_API_KEY is provided.
# ───────────────────────────────────────────────────────────────────────────

# --- Google Gemini (classification / extraction / embeddings) ---------------
# The ONLY online feature. https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Models (override only if you know what you want).
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_ESCALATION=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

# --- Local data location (optional) -----------------------------------------
# Where the SQLite database and original files are stored. Defaults to the OS
# per-user app-data directory (e.g. ~/.local/share/kura, %APPDATA%\kura,
# ~/Library/Application Support/kura).
# KURA_DATA_DIR=

# --- App ---------------------------------------------------------------------
# Public base URL of the app (used by the Tauri desktop shell to know where to
# send watched files, and for absolute links). Defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
