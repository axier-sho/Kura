# ───────────────────────────────────────────────────────────────────────────
# Kura environment variables
#
# Copy this file to `.env.local` and fill in the values.
# The app BUILDS and RUNS without any of these set AI/DB features simply
# activate once the corresponding keys are present (env-gating).
# ───────────────────────────────────────────────────────────────────────────

# --- Supabase (DB / Auth / Storage) -----------------------------------------
# From your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key server-side only. NEVER expose to the browser.
# Used by the cron notify route and background ingestion.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket name for original uploaded files (created by the migration notes).
SUPABASE_STORAGE_BUCKET=kura-documents

# --- Google Gemini (classification / extraction / embeddings) ---------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Models (override only if you know what you want).
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_ESCALATION=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Embedding dimensions MUST match the vector(...) size in the SQL migration.
GEMINI_EMBEDDING_DIM=768

# --- Email notifications (optional) -----------------------------------------
# https://resend.com when unset, notifications are logged instead of sent.
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=kura@example.com

# --- Cron protection ---------------------------------------------------------
# Shared secret required to call /api/cron/notify (sent as `Authorization: Bearer <secret>`).
CRON_SECRET=change-me

# --- App ---------------------------------------------------------------------
# Public base URL of the app (used by the Tauri desktop shell to know where to
# send watched files, and for absolute links). Defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
